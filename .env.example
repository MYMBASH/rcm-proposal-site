# ─────────────────────────────────────────────
# DigiMind Website — Environment Variables
# Copy this file to .env.local for local dev
# Set these in Vercel Dashboard → Settings → Environment Variables
# ─────────────────────────────────────────────

# PostgreSQL Database (get from Neon.tech, Supabase, or Vercel Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Session secret — generate a random 32+ char string
# Run: openssl rand -base64 32
SESSION_SECRET="your-very-long-random-secret-here"

# Vercel Blob Storage token (auto-set by Vercel when you add Blob storage)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Public site URL (your Vercel domain)
NEXT_PUBLIC_SITE_URL="https://your-project.vercel.app"
